# ============================================
# LUCERO TRP - Variables de Entorno (Ejemplo)
# ============================================

# Servidor
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# MongoDB
MONGODB_URI=mongodb://localhost:27017/lucero-trp

# JWT
JWT_SECRET=tu-secreto-aqui-cambiar-en-produccion
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=tu-refresh-secreto-aqui
JWT_REFRESH_EXPIRATION=7d

# WebSocket
WS_CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173

# Logs
LOG_LEVEL=debug
